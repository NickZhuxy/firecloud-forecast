{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Firecloud release report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "status",
    "branch",
    "pr_url",
    "merged",
    "issues_updated",
    "project_updated",
    "tests",
    "notes"
  ],
  "properties": {
    "version": { "const": 1 },
    "status": { "type": "string", "enum": ["released", "blocked", "skipped"] },
    "branch": { "type": "string" },
    "pr_url": { "type": ["string", "null"] },
    "merged": { "type": "boolean" },
    "issues_updated": {
      "type": "array",
      "items": { "type": "string" }
    },
    "project_updated": { "type": "boolean" },
    "tests": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
